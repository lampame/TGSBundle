{
  "name": "tgsbundle",
  "version": "1.0.0",
  "private": true,
  "description": "GramJS browser bundle for Telegram plugin usage",
  "scripts": {
    "prebuild": "cp patches/crypto.js node_modules/telegram/crypto/crypto.js",
    "build": "webpack --mode production && npx terser telegram.js --compress --mangle -o telegram.min.js"
  },
  "devDependencies": {
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "terser": "^5.31.6"
  },
  "dependencies": {
    "telegram": "2.26.22",
    "path-browserify": "^1.0.1",
    "os-browserify": "^0.3.0",
    "util": "^0.12.5",
    "buffer": "^6.0.3",
    "process": "^0.11.10"
  }
}
